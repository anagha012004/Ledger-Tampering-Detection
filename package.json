{
  "name": "ledger-tampering-detection",
  "version": "1.0.0",
  "description": "A demonstration project showing how distributed ledger systems detect data tampering through cryptographic hashing and consensus verification.",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently --kill-others --names \"BACKEND,FRONTEND\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && mvn spring-boot:run",
    "frontend": "cd frontend && npm run dev",
    "install:frontend": "cd frontend && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anagha012004/Ledger-Tampering-Detection.git"
  },
